# Copy this file to .env and fill in your values

# Supabase — same project as web platform
# Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Expo project ID — expo.dev → your project → Settings → Project ID
# Required for push notifications
EXPO_PUBLIC_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Web API base URL — your Vercel deployment URL
EXPO_PUBLIC_API_URL=https://your-app.vercel.app
